# Backend API base URL (including /api/v1 prefix). Required for release APK.
EXPO_PUBLIC_API_BASE_URL=https://backend.julow.ru/api/v1

# Unified OAuth callback for mobile (HTTPS page that bridges to julowmobile://oauth/callback).
# Must be registered as redirect URI in Google/GitHub/Yandex provider consoles.
EXPO_PUBLIC_OAUTH_REDIRECT_URI=https://julow.ru/oauth/mobile-callback
# The deep link scheme `julowmobile://oauth/callback` remains internal to app/browser bridge.

# Optional: Android emulator dev proxy (HTTP → host → HTTPS backend).
# Run in a second terminal: bun run emulator:proxy
# EXPO_PUBLIC_ANDROID_EMULATOR_API_BASE_URL=http://10.0.2.2:8787/api/v1

# Optional: local backend in Docker (port 8000)
# EXPO_PUBLIC_ANDROID_EMULATOR_API_BASE_URL=http://10.0.2.2:8000/api/v1
