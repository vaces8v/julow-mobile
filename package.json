{
  "name": "julow-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:metro": "powershell -ExecutionPolicy Bypass -File ./scripts/start-metro.ps1",
    "start:emu": "powershell -ExecutionPolicy Bypass -File ./scripts/fix-android-emulator-network.ps1 && node ./scripts/dev-emulator-proxy.mjs",
    "emulator:proxy": "node ./scripts/dev-emulator-proxy.mjs",
    "emulator:network": "powershell -ExecutionPolicy Bypass -File ./scripts/fix-android-emulator-network.ps1",
    "reset-project": "node ./scripts/reset-project.js",
    "postinstall": "patch-package",
    "android:fix": "node ./scripts/fix-android-locks.js",
    "metro:fix": "node ./scripts/fix-metro-cache.js",
    "android": "powershell -ExecutionPolicy Bypass -File ./scripts/run-android.ps1",
    "ios": "expo run:ios",
    "lint": "expo lint"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.0",
    "@config-plugins/react-native-webrtc": "^14.0.0",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react-native": "^1.0.13",
    "@livekit/react-native": "^2.11.0",
    "@livekit/react-native-expo-plugin": "^1.0.2",
    "@livekit/react-native-webrtc": "^144.1.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.2.5",
    "@shopify/react-native-skia": "2.6.2",
    "expo": "~56.0.6",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.15",
    "expo-camera": "^56.0.7",
    "expo-constants": "~56.0.16",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.9",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.12",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.0",
    "expo-router": "~56.2.7",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-video": "~56.1.2",
    "expo-web-browser": "~56.0.5",
    "heroui-native": "^1.0.0-rc.2",
    "livekit-client": "^2.19.0",
    "lucide-react-native": "^0.576.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "^1.21.8",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "0.35.9",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.0",
    "uniwind": "^1.3.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "patch-package": "^8.0.0",
    "sharp": "^0.34.5",
    "typescript": "~6.0.3"
  },
  "private": true,
  "trustedDependencies": [
    "@shopify/react-native-skia",
    "unrs-resolver"
  ],
  "reanimated": {
    "staticFeatureFlags": {
      "ENABLE_SHARED_ELEMENT_TRANSITIONS": false,
      "USE_COMMIT_HOOK_ONLY_FOR_REACT_COMMITS": false
    }
  }
}
